{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paperworks.local/schemas/runtime_trace_schema.json",
  "title": "Deterministic Rule Runtime Trace",
  "description": "LLM-free execution result for an accepted rule with hash-verified parameters.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "execution_id", "artifact_hash", "rule_id", "rule_hash", "verifier_result_ref", "input_window_id", "status", "trigger_satisfied", "expected_effect_satisfied", "violation_detected", "violation_score", "abstained", "satisfaction_trace", "parameter_values_used", "input_output_alignment_preserved", "created_at"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "execution_id": {"type": "string", "pattern": "^EXEC-[A-Z0-9-]{3,64}$"},
    "artifact_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "rule_id": {"type": "string", "pattern": "^RULE-[A-Z0-9-]{3,64}$"},
    "rule_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "verifier_result_ref": {"type": "string", "pattern": "^VERIFY-[A-Z0-9-]{3,64}$"},
    "input_window_id": {"type": "string", "pattern": "^WIN-[A-Z0-9-]{3,64}$"},
    "status": {"enum": ["evaluated", "abstained", "rejected_hash_mismatch", "rejected_schema_mismatch", "rejected_version_mismatch"]},
    "trigger_satisfied": {"type": "boolean"},
    "expected_effect_satisfied": {"type": ["boolean", "null"]},
    "violation_detected": {"type": "boolean"},
    "violation_score": {"type": "number", "minimum": 0, "maximum": 1},
    "abstained": {"type": "boolean"},
    "satisfaction_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "operator", "result", "parameter_refs", "variable_refs"],
        "properties": {
          "step": {"type": "integer", "minimum": 1},
          "operator": {"enum": ["regime_check", "trigger_check", "lag_check", "window_check", "relation_check", "tolerance_check", "persistence_check", "abstention_check", "output"]},
          "result": {"enum": ["satisfied", "violated", "not_applicable", "abstained"]},
          "parameter_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/parameter_id"}},
          "variable_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/variable"}}
        }
      }
    },
    "parameter_values_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["parameter_id", "parameter_hash", "value", "unit"],
        "properties": {
          "parameter_id": {"$ref": "#/$defs/parameter_id"},
          "parameter_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "value": {"type": "number"},
          "unit": {"type": "string", "pattern": "^[A-Za-z0-9_%./*^ -]{1,32}$"}
        }
      }
    },
    "input_output_alignment_preserved": {"const": true},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "variable": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,63}$"},
    "parameter_id": {"type": "string", "pattern": "^PARAM-(LAG|TOL|RATE|RANGE|DURATION|BASELINE|TRAJECTORY|SUPPORT|SEVERITY)-[0-9]{3,6}$"}
  }
}
