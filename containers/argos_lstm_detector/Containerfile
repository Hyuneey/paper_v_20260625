FROM docker.io/library/python@sha256:8fb099199b9f2d70342674bd9dbccd3ed03a258f26bbd1d556822c6dfc60c317

COPY requirements.lock /tmp/requirements.lock
RUN python -m pip install --no-cache-dir -r /tmp/requirements.lock \
    && rm -f /tmp/requirements.lock \
    && groupadd --gid 65532 task037a \
    && useradd --uid 65532 --gid 65532 --no-create-home --shell /usr/sbin/nologin task037a

COPY EasyTSAD /opt/easytsad/EasyTSAD
COPY --chown=65532:65532 detector_synthetic_smoke.py /runtime/detector_synthetic_smoke.py
WORKDIR /runtime
USER 65532:65532
ENTRYPOINT ["python", "/runtime/detector_synthetic_smoke.py"]
