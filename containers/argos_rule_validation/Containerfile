FROM docker.io/library/python@sha256:8fb099199b9f2d70342674bd9dbccd3ed03a258f26bbd1d556822c6dfc60c317

COPY requirements.lock /tmp/requirements.lock
RUN python -m pip install --no-cache-dir --require-hashes -r /tmp/requirements.lock \
    && rm /tmp/requirements.lock \
    && groupadd --gid 1000 task034 \
    && useradd --uid 1000 --gid 1000 --no-create-home --shell /usr/sbin/nologin task034

WORKDIR /app
COPY kpi_validation_entrypoint.py /app/kpi_validation_entrypoint.py

USER 1000:1000
ENTRYPOINT ["python", "/app/kpi_validation_entrypoint.py"]
